{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DSRV",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#support"
    },
    {
      "include": "#storage"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dsrv",
          "match": "\\b(if|then|else)\\b"
        },
        {
          "name": "keyword.operator.stringOps.dsrv",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.logical.dsrv",
          "match": "(\\&\\&|\\|\\||!|=>)"
        },
        {
          "name": "keyword.operator.comparison.dsrv",
          "match": "(==|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.dsrv",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.dsrv",
          "match": "="
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.dsrv",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.dsrv",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "name": "constant.language.boolean.dsrv",
      "match": "\\b(true|false)\\b"
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dsrv",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.dsrv",
          "begin": "\\(\\*",
          "end": "\\*\\)"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.function.builtin.dsrv",
          "match": "\\b(defer|update|is_defined|when|latch|dynamic|eval|default|init|monitored_at|dist)\\b(?=\\()"
        },
        {
          "name": "support.function.math.dsrv",
          "match": "\\b(sin|cos|tan|abs)\\b(?=\\()"
        },
        {
          "name": "support.function.list.dsrv",
          "match": "\\bList\\.(get|append|concat|head|tail|len)\\b(?=\\()"
        },
        {
          "name": "support.function.map.dsrv",
          "match": "\\bMap\\.(get|insert|remove|has_key)\\b(?=\\()"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.dsrv",
          "match": "\\b(in|out|var|aux)\\b"
        },
        {
          "name": "storage.type.builtin.dsrv",
          "match": "\\b(Int|Float|Bool|Str|Unit)\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.dsrv",
          "match": "[,:]"
        },
        {
          "name": "punctuation.section.brackets.dsrv",
          "match": "[\\[\\]\\(\\)\\{\\}]"
        }
      ]
    }
  },
  "scopeName": "source.dsrv"
}