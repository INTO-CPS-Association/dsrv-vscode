{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DSRV",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#support"
    },
    {
      "include": "#storage"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "types": {
      "patterns": [
        {
          "name": "meta.type.generic.dsrv",
          "begin": "\\b(Struct|List|Map)\\b\\s*(<)",
          "beginCaptures": {
            "1": {
              "name": "storage.type.builtin.dsrv"
            },
            "2": {
              "name": "punctuation.definition.generic.begin.dsrv"
            }
          },
          "end": ">",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.generic.end.dsrv"
            }
          },
          "patterns": [
            {
              "include": "#types"
            },
            {
              "name": "keyword.operator.ellipsis.dsrv",
              "match": "\\.\\.\\."
            },
            {
              "name": "variable.other.member.dsrv",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:)"
            },
            {
              "name": "punctuation.separator.dsrv",
              "match": "[,:]"
            }
          ]
        },
        {
          "name": "storage.type.builtin.dsrv",
          "match": "\\b(Int|Float|Bool|Str|Unit|List|Map|Struct)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dsrv",
          "match": "\\b(if|then|else)\\b"
        },
        {
          "name": "keyword.operator.ellipsis.dsrv",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.stringOps.dsrv",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.logical.dsrv",
          "match": "(\\&\\&|\\|\\||!|=>)"
        },
        {
          "name": "keyword.operator.comparison.dsrv",
          "match": "(!=|==|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.dsrv",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.dsrv",
          "match": "="
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.dsrv",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.dsrv",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.dsrv",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.dsrv",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.dsrv",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dsrv",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.dsrv",
          "begin": "\\(\\*",
          "end": "\\*\\)"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.function.builtin.dsrv",
          "match": "\\b(defer|update|is_defined|when|latch|dynamic|eval|default|init|monitored_at|dist)\\b(?=\\()"
        },
        {
          "name": "support.function.math.dsrv",
          "match": "\\b(sin|cos|tan|abs)\\b(?=\\()"
        },
        {
          "name": "support.function.list.dsrv",
          "match": "\\bList\\.(get|append|concat|head|tail|len)\\b(?=\\()"
        },
        {
          "name": "support.function.map.dsrv",
          "match": "\\bMap\\.(get|insert|remove|has_key)\\b(?=\\()"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.dsrv",
          "match": "\\b(in|out|var|aux)\\b"
        },
        {
          "name": "storage.type.builtin.dsrv",
          "match": "\\b(Int|Float|Bool|Str|Unit|List|Map|Struct)\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.dsrv",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.member.dsrv",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.dsrv",
          "match": "[,:]"
        },
        {
          "name": "punctuation.accessor.dsrv",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.generic.dsrv",
          "match": "[<>]"
        },
        {
          "name": "punctuation.section.brackets.dsrv",
          "match": "[\\[\\]\\(\\)\\{\\}]"
        }
      ]
    }
  },
  "scopeName": "source.dsrv"
}
