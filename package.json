{
  "name": "dsrv-vscode",
  "displayName": "DSRV Language Support for VSCode",
  "description": "VSCode extension for DSRV language support",
  "version": "0.0.1",
  "repository": {
    "url": "https://github.com/INTO-CPS-Association/dsrv-vscode.git",
    "type": "git"
  },
  "icon": "./assets/favicon-32x32.png",
  "license": "GPL-3.0-only",
  "engines": {
    "vscode": "^1.107.0"
  },
  "keywords": [
    "dsrv"
  ],
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "dsrv",
        "aliases": [
          "DSRV",
          "dsrv"
        ],
        "icon": {
          "light": "./assets/favicon-32x32.png",
          "dark": "./assets/favicon-32x32.png"
        },
        "extensions": [
          ".dsrv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dsrv",
        "scopeName": "source.dsrv",
        "path": "./syntaxes/dsrv.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "DSRV",
      "properties": {
        "DSRV.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the executable of the trustworthiness checker",
          "scope": "resource"
        },
        "DSRV.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the dsrv-lsp executable. If empty, dsrv-lsp is resolved from PATH.",
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "DSRV.runCurrentFile",
        "title": "Run DSRV",
        "icon": "$(play)"
      },
      {
        "command": "DSRV.runWithInput",
        "title": "Choose Input File and Run DSRV",
        "icon": "$(play)"
      },
      {
        "command": "DSRV.runWithTypes",
        "title": "Run DSRV with Typed semantics",
        "icon": "$(play)"
      },
      {
        "command": "DSRV.runWithInputAndTypes",
        "title": "Choose Input file and run with Typed semantics",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "DSRV.runCurrentFile",
          "when": "resourceLangId == dsrv  && !inDiffEditor",
          "group": "navigation@0"
        },
        {
          "command": "DSRV.runWithInput",
          "when": "resourceLangId == dsrv  && !inDiffEditor",
          "group": "navigation@1"
        },
        {
          "command": "DSRV.runWithTypes",
          "when": "resourceLangId == dsrv && !inDiffEditor",
          "group": "navigation@2"
        },
        {
          "command": "DSRV.runWithInputAndTypes",
          "when": "resourceLangId == dsrv  && !inDiffEditor",
          "group": "navigation@3"
        }
      ]
    },
    "configurationDefaults": {
      "[dsrv]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": true
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build -- --minify",
    "build": "npm run build-base -- --sourcemap",
    "build-debug": "npm run build-base -- --sourcemap",
    "test:all": "npm run test:ts",
    "test:ts": "npm run build-base && vscode-test",
    "build-base": "node esbuild.js",
    "package": "vsce package",
    "check-types": "tsc --noEmit",
    "watch": "npm run build-base -- --sourcemap --watch",
    "lint": "eslint client/src extension.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "mocha": "^11.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
